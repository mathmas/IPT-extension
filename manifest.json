{
  "manifest_version": 3,
  "name": "Auto Fill Document Label",
  "version": "0.2",
  "description": "Fill Document Label",
  
  "permissions": [
    "activeTab"
  ],

  "icons": {
    "48": "icone.png",
    "128": "icone.png"
  },
  "content_scripts": [
    {
      "matches": ["https://app.ipaidthat.io/*"],
      "js": [
        "src/main.js"
      ],
      "run_at": "document_end"
    }
  ],

    "browser_specific_settings": {
        "gecko": {
        "id": "autofiller-id-label@monsite.private",
        "data_collection_permissions": {
        "required": [
          "none"
        ]
      }
        }
    }
}